{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "paths": {
      "@omniwatch/shared": ["./packages/shared/src/index.ts"],
      "@omniwatch/db": ["./packages/db/src/index.ts"]
    }
  },
  "include": [
    "apps/*/src/**/*.ts",
    "apps/*/src/**/*.tsx",
    "packages/*/src/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", ".next"]
}
