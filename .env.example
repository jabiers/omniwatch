# ──────────────────────────────────────────────────────────────────────────────
# OmniWatch Environment Variables
# Copy this file to .env and fill in the values you need.
# ──────────────────────────────────────────────────────────────────────────────

# ─── General ──────────────────────────────────────────────────────────────────

# Runtime environment (development | production)
NODE_ENV=development

# Data directory for SQLite DB, agent files, logs (default: ~/.omniwatch)
# OMNI_DATA_DIR=~/.omniwatch

# API server port (default: 3456)
# PORT=3456

# CORS allowed origins (comma-separated, default: http://localhost:3457)
# CORS_ORIGINS=http://localhost:3457,https://your-domain.com

# ─── AI Providers ─────────────────────────────────────────────────────────────

# Anthropic (Claude) API key — required for Claude-based agents
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key — required for GPT-based agents
# OPENAI_API_KEY=sk-...

# Ollama base URL — required for local LLM agents (default: http://localhost:11434)
# OLLAMA_URL=http://localhost:11434

# ─── GitHub OAuth ─────────────────────────────────────────────────────────────

# GitHub OAuth App credentials for login
# Create at: https://github.com/settings/developers
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# GitHub OAuth callback URL (default: auto-detected from request origin)
# GITHUB_REDIRECT_URI=http://localhost:3456/auth/github/callback

# ─── Google OAuth ─────────────────────────────────────────────────────────────

# Google OAuth credentials for login
# Create at: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Google OAuth callback URL (default: auto-detected from request origin)
# GOOGLE_REDIRECT_URI=http://localhost:3456/auth/google/callback

# ─── Notifications ────────────────────────────────────────────────────────────

# Slack incoming webhook URL for notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Discord webhook URL for notifications
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Telegram bot token and chat ID for notifications
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
