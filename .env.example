# ──────────────────────────────────────────────────────────────────────────────
# OmniWatch Environment Variables
# Copy this file to .env and fill in the values you need.
# ──────────────────────────────────────────────────────────────────────────────

# === Authentication ===

# Default admin API key (auto-generated on first boot if not set)
# OMNI_ADMIN_KEY=omni_your_key_here

# === OAuth (Optional) ===

# GitHub OAuth - https://github.com/settings/developers
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_CALLBACK_URL=http://localhost:3457/api/auth/github/callback

# Google OAuth - https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:3457/api/auth/google/callback

# === AI Providers ===

# Anthropic (Claude) API key — required for Claude-based agents
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI API key — required for GPT-based agents
# OPENAI_API_KEY=sk-xxxxx

# Ollama base URL — required for local LLM agents (default: http://localhost:11434)
# OLLAMA_URL=http://localhost:11434

# === Server ===

# Runtime environment (development | production)
# NODE_ENV=development

# API server port (default: 3456)
# PORT=3456

# Data directory for SQLite DB, agent files, logs (default: ~/.omniwatch)
# OMNI_DATA_DIR=~/.omniwatch

# Log level (debug | info | warn | error)
# LOG_LEVEL=info

# CORS allowed origins (comma-separated, default: http://localhost:3457)
# CORS_ORIGINS=http://localhost:3457,https://your-domain.com

# === Notifications ===

# Slack incoming webhook URL for notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Discord webhook URL for notifications
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Telegram bot token and chat ID for notifications
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# === Development ===

# Skip auth in dev mode (never use in production)
# OMNIWATCH_DEV_AUTH=1
