{
  "name": "omniwatch",
  "version": "0.3.0",
  "description": "AI-native CLI tool for autonomous agent management. Don't Config, Just Speak.",
  "type": "module",
  "bin": {
    "omni": "./bin/omni.mjs"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "dev:daemon": "tsx src/daemon/index.ts",
    "build": "tsup",
    "test": "vitest",
