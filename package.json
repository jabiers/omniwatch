  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "acorn": "^8.16.0",
    "better-sqlite3": "^11.7.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ink": "^6.8.0",
    "nanoid": "^5.0.9",
    "ora": "^8.1.1",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "tsup": "^8.3.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
